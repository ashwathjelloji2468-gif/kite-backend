 {
  "rewrites": [
    {
      "source": "/support",
      "destination": "https://kite-backend-m7yt.vercel.app/support"
    },
    {
      "source": "/support/:path*",
      "destination": "https://kite-backend-m7yt.vercel.app/support/:path*"
    },
    {
      "source": "/static/:path*",
      "destination": "/static/:path*"
    },
    {
      "source": "/((?!support|static).*)",
      "destination": "/index.html"
    }
  ]
}